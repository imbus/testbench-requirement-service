# Example environment file for JiraRequirementReader authentication
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file with real credentials!

# Basic Authentication (most common for Atlassian Cloud)
# On Jira Cloud the password is an API token (generate at id.atlassian.com).
# On Jira Data Center use your regular account password.
JIRA_USERNAME=your-email@example.com
JIRA_PASSWORD=your-api-token-or-password-here

# Token Authentication (for Jira Server/Data Center with Personal Access Tokens)
# JIRA_BEARER_TOKEN=your-personal-access-token

# OAuth1 Authentication (for enterprise instances)
# JIRA_OAUTH1_ACCESS_TOKEN=your-access-token
# JIRA_OAUTH1_ACCESS_TOKEN_SECRET=your-access-token-secret
# JIRA_OAUTH1_CONSUMER_KEY=your-consumer-key
# JIRA_OAUTH1_KEY_CERT=path/to/your/private-key.pem
